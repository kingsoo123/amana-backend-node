PORT=3001

# Production (Neon): set DATABASE_URL and the app will use it with SSL.
# DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
# If IPv6 causes ENETUNREACH on your network, the app forces IPv4 automatically.
# Optional: DATABASE_USE_POOLER=true uses Neon pooler hostname (-pooler)

# Local Docker Postgres (used when DATABASE_URL is unset)
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=amana
DATABASE_PASSWORD=amana
DATABASE_NAME=amana

# Set to false in production once you move to migrations
DATABASE_SYNCHRONIZE=true

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h
FRONTEND_URL=https://payonce.netlify.app,http://localhost:3000
# Comma-separated browser origins allowed to call the API directly (optional).
# ALLOWED_ORIGINS=http://localhost:3000,https://your-site.netlify.app
# Allow all *.netlify.app preview URLs (default: true)
ALLOW_NETLIFY_PREVIEWS=true
FLUTTERWAVE_CLIENT_ID=
FLUTTERWAVE_CLIENT_SECRET=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_API_MODE=auto
FLUTTERWAVE_WEBHOOK_HASH=
FLUTTERWAVE_WEBHOOK_MOCK=true
FLUTTERWAVE_ENV=sandbox
ADMIN_EMAIL=admin@amana.local

# True escrow hold: buyers pay the admin user's active DVA; release pays out to seller DVA
# Ensure ADMIN_EMAIL (or another admin) has created a virtual account in Settings.
ESCROW_TRUE_HOLD=true
# Mock Flutterwave transfers when secret key is missing (default) or force:
ESCROW_PAYOUT_MOCK=true

# Partner / marketplace API (Delivery Assurance)
# Create partners via POST /api/v1/admin/partners (admin JWT)
# Create keys via POST /api/v1/admin/partners/:id/api-keys

# Cloudinary — dispute evidence uploads (signed client upload)
CLOUDINARY_CLOUD_NAME=da8syamxo
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
